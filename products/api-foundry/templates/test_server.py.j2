# ==============================================================================
# 1. PROTOCOL COMPLIANCE & DISCOVERY
# ==============================================================================

@pytest.mark.asyncio
async def test_tools_list_returns_correct_number_of_tools(mcp_server):
    """Test that all generated tools are correctly registered with names and descriptions."""
    tools = mcp_server._tools.values() if hasattr(mcp_server, "_tools") else []
    if not tools:
        # Fallback to listing directly
        tools = await mcp_server.list_tools()
        
    assert len(tools) >= {{ tool_count }}
    for tool in tools:
        assert tool.name is not None
        assert tool.description is not None

