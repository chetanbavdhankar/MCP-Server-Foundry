def format_validation_error(pydantic_error: Exception, request_id: str) -> ValidationError:
    """
    Convert a Pydantic ValidationError to our ValidationError schema.
    
    Args:
        pydantic_error: Pydantic validation exception
        request_id: Request ID for tracing
        
    Returns:
        ValidationError instance
    """
    field_errors = {}
    
    # Parse Pydantic error format
    if hasattr(pydantic_error, 'errors'):
        for error in pydantic_error.errors():
            field = '.'.join(str(loc) for loc in error['loc'])
            message = error['msg']
            
            if field not in field_errors:
                field_errors[field] = []
            field_errors[field].append(message)
    
    return ValidationError(
        message="Input validation failed",
        field_errors=field_errors,
        request_id=request_id
    )


def format_http_error(status_code: int, response_text: str, request_id: str) -> MCPError:
    """
    Convert an HTTP error to an appropriate error schema.
    
    Args:
        status_code: HTTP status code
        response_text: Response body from upstream
        request_id: Request ID for tracing
        
    Returns:
        Appropriate error instance based on status code
    """
    if status_code == 401:
        return AuthenticationError(
            message="Authentication failed",
            details={"status_code": status_code},
            request_id=request_id
        )
    elif status_code == 403:
        return AuthorizationError(
            message="Access denied",
            details={"status_code": status_code},
            request_id=request_id
        )
    elif status_code == 429:
        return RateLimitError(
            message="Rate limit exceeded",
            details={"status_code": status_code},
            request_id=request_id
        )
    elif status_code >= 500:
        return UpstreamError(
            message="Upstream service error",
            status_code=status_code,
            upstream_message=response_text[:200] if response_text else None,
            request_id=request_id
        )
    else:
        return UpstreamError(
            message=f"Upstream returned status {status_code}",
            status_code=status_code,
            upstream_message=response_text[:200] if response_text else None,
            request_id=request_id
        )


