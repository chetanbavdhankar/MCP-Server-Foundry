# ==============================================================================
# MCP Server Foundry - Multi-Model Pipeline Configuration
# ==============================================================================
# The core pipeline generates code deterministically and does not strictly 
# require these keys. However, if you enable intelligent multi-model routing 
# (Milestone 6) for complex architectures, the pipeline will use these keys.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Cloud LLM Providers (Optional)
# ------------------------------------------------------------------------------
# API keys for cloud-based large language models.
#
# Get your Anthropic API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# Get your Google Gemini API key from: https://aistudio.google.com/
GEMINI_API_KEY=AIzaSy...


# ------------------------------------------------------------------------------
# 2. Local Ollama Provider (Optional)
# ------------------------------------------------------------------------------
# If you want to use local open-source models completely free and offline.
# Ensure Ollama is running via `ollama serve`.
#
# Default endpoint is http://localhost:11434
# OLLAMA_ENDPOINT=http://localhost:11434

# You can specify which local model to use for fallback routing (e.g., qwen3.5:4b, mistral, phi3)
# Make sure you have pulled it first: `ollama pull qwen3.5:4b`
# OLLAMA_DEFAULT_MODEL=qwen3.5:4b
