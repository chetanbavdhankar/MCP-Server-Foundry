#!/bin/bash
# BobShell Run Script for {{ api_title }} MCP Server
# Generated by MCP Server Foundry (Milestone 5)

set -e

echo "============================================================"
echo "🚀 Starting {{ api_title }} MCP Server"
echo "============================================================"

# 1. Check if .env file exists
if [ ! -f .env ]; then
    echo "⚠️  WARNING: .env file not found!"
    if [ -f .env.example ]; then
        echo "💡 Copying .env.example to .env..."
        cp .env.example .env
        echo "👉 Please edit the .env file with your actual API credentials before launching!"
        exit 1
    else
        echo "❌ ERROR: Neither .env nor .env.example exists."
        exit 1
    fi
fi

# 2. Source the environment variables
echo "⚙️  Loading environment configuration..."
export $(grep -v '^#' .env | xargs)

# 3. Check required variables
MISSING_VARS=0
{%- for var in env_vars %}
if [ -z "${{ var.key }}" ]; then
    echo "❌ ERROR: Required environment variable '{{ var.key }}' is not set."
    MISSING_VARS=1
fi
{%- endfor %}

if [ $MISSING_VARS -eq 1 ]; then
    echo "👉 Please set all required variables in your .env file."
    exit 1
fi

# 4. Check dependencies
echo "📦 Verifying python environment dependencies..."
python3 -c "import pydantic" 2>/dev/null || {
    echo "❌ ERROR: Pydantic is not installed."
    echo "👉 Run: pip install pydantic"
    exit 1
}

# 5. Run the MCP server
echo "🔌 Launching MCP Server via stdio transport..."
echo "--- Press Ctrl+C to terminate ---"
python3 main.py
