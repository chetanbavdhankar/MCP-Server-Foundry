class TestProtocol:
    """MCP protocol-level tests."""

    @pytest.mark.asyncio
    async def test_initialize_returns_server_info(self, server, make_request):
        resp = await server.handle_request(make_request("initialize"))
        assert resp.error is None
        assert resp.result is not None
        assert "serverInfo" in resp.result
        assert "protocolVersion" in resp.result

    @pytest.mark.asyncio
    async def test_tools_list_returns_{{ tool_count }}_tools(self, server, make_request):
        resp = await server.handle_request(make_request("tools/list"))
        assert resp.error is None
        tools = resp.result["tools"]
        assert len(tools) == {{ tool_count }}
        # Every tool must have name, description, inputSchema
        for tool in tools:
            assert "name" in tool
            assert "description" in tool
            assert "inputSchema" in tool

    @pytest.mark.asyncio
    async def test_unknown_method_returns_error(self, server, make_request):
        resp = await server.handle_request(make_request("nonexistent/method"))
        assert resp.error is not None
        assert resp.error["code"] == -32601  # Method not found

    @pytest.mark.asyncio
    async def test_tools_call_missing_name_returns_error(self, server, make_request):
        resp = await server.handle_request(make_request("tools/call", params={}))
        assert resp.error is not None
        assert resp.error["code"] == -32602  # Invalid params

    @pytest.mark.asyncio
    async def test_tools_call_unknown_tool_returns_error(self, server, make_request):
        resp = await server.handle_request(
            make_request("tools/call", params={"name": "nonexistent-tool", "arguments": {}})
        )
        assert resp.error is not None


