"""
Audit logging for MCP server runtime.

Generated by MCP Server Foundry (Milestone 3).
Provides structured JSON Lines logging for every tool invocation.
"""

import json
import time
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, Optional


class RuntimeAuditLogger:
    """
    Append-only audit logger for generated MCP servers.

    Logs every tool call with: request ID, tool name, parameters (sanitized),
    response status, latency, and error details if applicable.
    """

    def __init__(self, log_path: str = "./audit.log"):
        self.log_path = Path(log_path)
        self.log_path.parent.mkdir(parents=True, exist_ok=True)

    def log_tool_call(
        self,
        request_id: str,
        tool_name: str,
        arguments: Dict[str, Any],
    ):
        """Record a tool invocation."""
        self._write({
            "event": "tool.call",
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "request_id": request_id,
            "tool": tool_name,
            "arguments": self._sanitize_args(arguments),
        })

    def log_tool_result(
        self,
        request_id: str,
        tool_name: str,
        duration_ms: float,
        success: bool,
        error: Optional[str] = None,
    ):
        """Record a tool result."""
        entry = {
            "event": "tool.result",
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "request_id": request_id,
            "tool": tool_name,
            "duration_ms": round(duration_ms, 2),
            "success": success,
        }
        if error:
            entry["error"] = error
        self._write(entry)

    def log_auth_failure(self, request_id: str, reason: str):
        """Record an authentication failure."""
        self._write({
            "event": "auth.failure",
            "severity": "SECURITY",
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "request_id": request_id,
            "reason": reason,
        })

    def _sanitize_args(self, args: Dict[str, Any]) -> Dict[str, Any]:
        """Redact sensitive-looking argument values."""
        sanitized = {}
        sensitive_keys = {"password", "secret", "token", "key", "credential", "auth"}
        for k, v in args.items():
            if any(s in k.lower() for s in sensitive_keys):
                sanitized[k] = "***REDACTED***"
            elif isinstance(v, str) and len(v) > 500:
                sanitized[k] = v[:500] + "...[truncated]"
            else:
                sanitized[k] = v
        return sanitized

    def _write(self, entry: Dict[str, Any]):
        """Append a single JSON line to the log file."""
        with open(self.log_path, "a", encoding="utf-8") as f:
            f.write(json.dumps(entry, separators=(",", ":")) + "\n")
